<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/registerRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F1115">

    <LinearLayout
        android:id="@+id/registerContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="24dp">

        <TextView
            android:id="@+id/textViewRegisterTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="建立帳號"
            android:textColor="#F5D432"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textViewRegisterSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="20dp"
            android:text="請填寫以下資料完成註冊"
            android:textColor="#F5F7FA"
            android:textSize="14sp" />

        <LinearLayout
            android:id="@+id/registerCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_from_card_dark"
            android:orientation="vertical"
            android:padding="24dp">

            <EditText
                android:id="@+id/editText_register_account"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input_dark"
                android:hint="帳號"
                android:inputType="text"
                android:minHeight="56dp"
                android:padding="16dp"
                android:textColor="#F5F7FA"
                android:textColorHint="#8B95A7"
                android:textSize="18sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editText_register_password"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_input_dark"
                android:hint="密碼"
                android:inputType="textPassword"
                android:minHeight="56dp"
                android:padding="16dp"
                android:textColor="#F5F7FA"
                android:textColorHint="#8B95A7"
                android:textSize="18sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editText_register_confirm_password"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_input_dark"
                android:hint="確認密碼"
                android:inputType="textPassword"
                android:minHeight="56dp"
                android:padding="16dp"
                android:textColor="#F5F7FA"
                android:textColorHint="#8B95A7"
                android:textSize="18sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editText_securityQuestion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_input_dark"
                android:hint="你最喜歡的歌曲"
                android:inputType="text"
                android:minHeight="56dp"
                android:padding="16dp"
                android:textColor="#F5F7FA"
                android:textColorHint="#8B95A7"
                android:textSize="18sp"
                android:textStyle="bold" />

        </LinearLayout>

        <Button
            android:id="@+id/button_register_confirm"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_btn_primary_yellow"
            android:text="確認註冊"
            android:textAllCaps="false"
            android:textColor="#121212"
            android:textSize="18sp"
            android:textStyle="bold"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/button_register_cancel"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_btn_secondary"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:text="返回登入"
            android:textAllCaps="false"
            android:textColor="#F5F7FA"
            android:textSize="16sp"
            app:backgroundTint="@null" />

    </LinearLayout>

</FrameLayout>