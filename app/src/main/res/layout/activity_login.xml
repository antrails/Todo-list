<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/loginRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F1115">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="24dp">

        <TextView
            android:id="@+id/textViewTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="歡迎回來"
            android:textColor="#F5D432"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textViewSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="20dp"
            android:text="請先登入帳號，若還沒有帳號可先註冊"
            android:textColor="#F5F7FA"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_from_card_dark"
            android:padding="24dp">

            <EditText
                android:id="@+id/editText_account"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input_dark"
                android:hint="帳號"
                android:inputType="text"
                android:minHeight="56dp"
                android:padding="16dp"
                android:textColor="#F5F7FA"
                android:textColorHint="#8B95A7"
                android:textSize="18sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editText_passwd"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_input_dark"
                android:hint="密碼"
                android:inputType="textPassword"
                android:minHeight="56dp"
                android:padding="16dp"
                android:textColor="#F5F7FA"
                android:textColorHint="#8B95A7"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <Button
            android:id="@+id/button_Login"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_btn_primary_yellow"
            android:text="登入"
            android:textAllCaps="false"
            android:textColor="#121212"
            android:textSize="18sp"
            android:textStyle="bold"
            app:backgroundTint="@null" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="18dp"
            android:text="還沒有帳號？"
            android:textColor="#8B95A7"
            android:textSize="14sp" />

        <Button
            android:id="@+id/button_Register"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_btn_secondary"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:text="前往註冊"
            android:textAllCaps="false"
            android:textColor="#F5F7FA"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@null" />

    </LinearLayout>

</FrameLayout>